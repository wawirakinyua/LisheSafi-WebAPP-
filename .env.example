# Copy this file to .env and fill in real values once your teammate's
# backend is up. Vite only reads variables prefixed with VITE_.

# 'local'  -> uses browser localStorage as a stand-in backend (default, no setup needed)
# 'api'    -> calls the real backend server described in src/services/cloudLedgerApi.js
VITE_BACKEND_MODE=local

# Base URL of your teammate's backend server (only used when VITE_BACKEND_MODE=api)
VITE_API_BASE_URL=http://localhost:4000
